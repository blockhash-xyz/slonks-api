# Postgres connection. Use Neon, Fly Managed Postgres, or anything that speaks pg.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/slonks

# Mainnet RPC. Alchemy strongly preferred — renderEmbeddingPixels eth_call needs ~140M gas.
ALCHEMY_API_KEY=

# Optional. Enables /listings by proxying OpenSea v2 with a server-side key.
OPENSEA_API_KEY=
OPENSEA_SLUG=slonks

# Optional fallback if ALCHEMY_API_KEY is unset. Many public RPCs reject the heavy eth_call.
RPC_URL=

# Block to start backfilling Slonks events from. Defaults to Slonks deploy block 24998760.
# Override during dev to start from a recent block.
START_BLOCK=

# How many blocks to scan per eth_getLogs call during backfill. Alchemy caps around 10k, default is conservative.
LOG_RANGE=2000

# Live-sync poll interval in ms.
SYNC_INTERVAL_MS=12000

# HTTP port for the web process.
PORT=8080

# Comma-separated allowlist of CORS origins. Empty = allow all.
CORS_ORIGINS=
