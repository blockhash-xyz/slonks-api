{
  "name": "slonks",
  "version": "0.1.3",
  "description": "Monorepo for the Slonks API, CLI, and shared model code.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/blockhash-xyz/slonks-api.git"
  },
  "bugs": {
    "url": "https://github.com/blockhash-xyz/slonks-api/issues"
  },
  "homepage": "https://github.com/blockhash-xyz/slonks-api#readme",
  "scripts": {
    "cli": "bun packages/cli/src/cli/slonks.ts",
    "dev:web": "bun --watch packages/api/src/web.ts",
    "dev:prover": "bun --watch packages/api/src/proverWeb.ts",
    "dev:indexer": "bun --watch packages/api/src/indexer/index.ts",
    "start:web": "bun packages/api/src/web.ts",
    "start:prover": "bun packages/api/src/proverWeb.ts",
    "start:indexer": "bun packages/api/src/indexer/index.ts",
    "slop:mine": "bun packages/cli/src/cli/slonks.ts mine",
    "publish:cli:dry": "cd packages/cli && bun publish --dry-run",
    "publish:cli": "cd packages/cli && bun publish --access public",
    "deploy:api": "fly deploy -c packages/api/fly.toml .",
    "deploy:prover": "fly deploy -c packages/api/fly.prover.toml .",
    "test": "bun test",
    "test:api": "bun test packages/core packages/api",
    "test:cli": "bun test packages/cli",
    "test:core": "bun test packages/core",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config packages/api/drizzle.config.ts",
    "db:migrate": "bun packages/api/src/db/migrate.ts",
    "db:studio": "drizzle-kit studio --config packages/api/drizzle.config.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.3"
  }
}
